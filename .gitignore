# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so

# ─── Virtual Environment ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env.bak

# ─── CRITICAL: Environment Variables (contains secrets & passwords) ────────────
.env

